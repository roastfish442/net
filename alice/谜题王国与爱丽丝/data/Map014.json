{"id":2,"name":"EV002","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"Actor2","direction":2,"pattern":1,"characterIndex":1},"list":[{"code":231,"indent":0,"parameters":[1,"青虫01",1,0,416,432,40,40,0,0]},{"code":232,"indent":0,"parameters":[1,0,1,0,416,432,40,40,255,0,15,true,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"？？"]},{"code":401,"indent":0,"parameters":["你好，爱丽丝，我们很久没见了。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":0,"parameters":["请问您是……"]},{"code":101,"indent":0,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":0,"parameters":["看来，漫长的时光带走了您的记忆。我是毛毛虫，"]},{"code":401,"indent":0,"parameters":["是谜题森林里最博学的虫子。"]},{"code":111,"indent":0,"parameters":[0,25,0]},{"code":101,"indent":1,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":1,"parameters":["毛毛虫先生，为什么我想穿过森林，却又回到了起点？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":1,"parameters":["谜题森林的上空笼罩着迷雾，你需要用灯光来驱散它，"]},{"code":401,"indent":1,"parameters":["才能顺利通过。"]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":101,"indent":1,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":1,"parameters":["毛毛虫先生你好，请问离红心女王的城堡还有多远？"]},{"code":101,"indent":1,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":1,"parameters":["只要穿过谜题森林，红心女王的城堡就近在眼前了。"]},{"code":101,"indent":1,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":1,"parameters":["但谜题森林的上空笼罩着迷雾，你需要用灯光来驱散它，"]},{"code":401,"indent":1,"parameters":["才能顺利通过。"]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":0,"parameters":["那我该去哪里寻找灯光呢？"]},{"code":101,"indent":0,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":0,"parameters":["我这里刚好有一盏灯，可以送给你。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":0,"parameters":["太好了，谢谢你！"]},{"code":101,"indent":0,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":0,"parameters":["不过，多年没见，你是否还像以前那样聪慧呢，爱丽丝。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":0,"parameters":["如果又像上次一样解不开谜题，可是又会惹红心女王生气的。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":0,"parameters":["来试试看吧。如果你能破解藏书中隐藏的5位数密码，"]},{"code":401,"indent":0,"parameters":["我就把这盏灯交给你。"]},{"code":101,"indent":0,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":0,"parameters":["好吧……"]},{"code":123,"indent":0,"parameters":["A",0]},{"code":121,"indent":0,"parameters":[26,26,0]},{"code":235,"indent":0,"parameters":[1]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":13,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":26,"switch1Valid":true,"switch2Id":26,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"Actor2","direction":2,"pattern":1,"characterIndex":1},"list":[{"code":231,"indent":0,"parameters":[1,"青虫01",1,0,416,432,40,40,0,0]},{"code":232,"indent":0,"parameters":[1,0,1,0,416,432,40,40,255,0,15,true,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":0,"parameters":["爱丽丝，你已经解开密码了吗？还是说，有什么事要问？"]},{"code":102,"indent":0,"parameters":[["有事要问","解开了密码"],1,0,2,0]},{"code":402,"indent":0,"parameters":[0,"有事要问"]},{"code":101,"indent":1,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":1,"parameters":["毛毛虫先生，我有事要问。"]},{"code":102,"indent":1,"parameters":[["关于爱丽丝和女王","关于右边的栅栏","关于毛毛虫"],1,0,2,0]},{"code":402,"indent":1,"parameters":[0,"关于爱丽丝和女王"]},{"code":101,"indent":2,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":2,"parameters":["您好像知道爱丽丝和女王之间发生了什么？"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["作为爱丽丝，你应该比我更清楚才对。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":2,"parameters":["可我并不是真正的爱丽丝。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["……仔细一看，你的确和那位爱丽丝有些微妙的不同啊。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["不过这并没有什么关系，所谓的“爱丽丝”也只是一个称呼，"]},{"code":401,"indent":2,"parameters":["一个姓名。你想要见到红心女王，那你就是爱丽丝。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":2,"parameters":["那么您能告诉我，之前的爱丽丝和女王之间发生了什么吗？"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["哦，那是一个风和日丽，阳光明媚的日子。像往常一样，"]},{"code":401,"indent":2,"parameters":["爱丽丝破解了女王的一道又一道谜题，来到城堡觐见女王。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["但面对女王的最后一道谜题，爱丽丝却怎么也解不开。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["女王勃然大怒，下令将爱丽丝逐出谜题王国。"]},{"code":401,"indent":2,"parameters":["从此，爱丽丝就再也没有回来过。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":2,"parameters":["这么说，爱丽丝是被女王逐出谜题王国的？"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["我想女王当时就后悔了，但那位爱丽丝从此也再没回来过。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":2,"parameters":["原来如此……"]},{"code":101,"indent":2,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":2,"parameters":["（如果我也解不开最后的谜题，红心女王是不是也会"]},{"code":401,"indent":2,"parameters":["把我逐出去？这样我就能回家了……）"]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[1,"关于右边的栅栏"]},{"code":101,"indent":2,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":2,"parameters":["右边放着的那些栅栏是什么？里面好像什么都没有。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["哦，那是公爵夫人留下的猪圈，但猪都跑光了，"]},{"code":401,"indent":2,"parameters":["现在只是普通的栅栏了。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":2,"parameters":["……"]},{"code":0,"indent":2,"parameters":[]},{"code":402,"indent":1,"parameters":[2,"关于毛毛虫"]},{"code":101,"indent":2,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":2,"parameters":["毛毛虫先生，你在这里多久了？"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["哦，时间久到我自己都记不清了。从谜题王国诞生"]},{"code":401,"indent":2,"parameters":["之后，我就一直在这里。那时候有爱丽丝在，大家"]},{"code":401,"indent":2,"parameters":["都过着快乐的日子，不过好景不长啊……"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["我一直都相信，爱丽丝早晚会回来。"]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"解开了密码"]},{"code":101,"indent":1,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":1,"parameters":["那就请把你的答案告诉我吧。"]},{"code":103,"indent":1,"parameters":[7,5]},{"code":111,"indent":1,"parameters":[1,7,0,13935,0]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["很好，你成功地破解了这个谜题，这个提灯是你的了。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["如果是你的话，肯定也能破解红心女王最后的谜题吧。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["其实我一直不明白，那么简单的谜题，爱丽丝为什么"]},{"code":401,"indent":2,"parameters":["一直解不开呢。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"方绮"]},{"code":401,"indent":2,"parameters":["最后的谜题很简单吗？"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["是啊。也许对于其他人来说，这道题很难。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"]},{"code":401,"indent":2,"parameters":["但只要掌握了相应的知识，那道题本该迎刃而解才对。"]},{"code":101,"indent":2,"parameters":["",0,0,2,"毛毛虫"